{% extends 'base.html.twig' %}

{% block title %}Mon Profil{% endblock %}

{% block body %}
<div class="container mx-auto my-8">
    <h1 class="text-3xl font-bold mb-4">Mon Profil</h1>
    <div class="bg-white shadow-md rounded-lg p-6 mb-6">
        <h2 class="text-2xl font-semibold mb-2">{{ user.name }}</h2>
        <p class="text-gray-700 mb-2"><strong>Email:</strong> {{ user.email }}</p>
        <p class="text-gray-700 mb-2"><strong>Téléphone:</strong> {{ user.phone }}</p>
    </div>

    <h2 class="text-xl font-bold mb-4">Modifier mes informations</h2>
    {{ form_start(form) }}
        {{ form_widget(form) }}
        <button type="submit" class="mt-4 bg-blue-500 text-white font-bold py-2 px-4 rounded">Modifier</button>
    {{ form_end(form) }}
</div>

{% endblock %}
