{% extends 'base.html.twig' %}

{% block title %}Toutes les Paires{% endblock %}

{% block body %}
  <header class="bg-gray-800 text-white p-4">
    <nav class="container mx-auto flex justify-between items-center">
      <a href="{{ path('landing') }}" class="text-xl font-bold">SneakerShop</a>
      <ul class="flex space-x-4">
        <li><a href="{{ path('profile') }}" class="hover:underline">Mon Profil</a></li>
      </ul>
    </nav>
  </header>

  <main class="container mx-auto my-8">
    <section class="all-pairs">
      <h2 class="text-2xl font-semibold mb-6">Toutes les Paires</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
        {% for article in articles %}
          <div class="bg-white rounded-lg shadow-md overflow-hidden">
            <img src="{{ article.imageUrl }}" class="w-full h-48 object-cover" alt="{{ article.nom }}">
            <div class="p-4">
              <h5 class="text-lg font-semibold">{{ article.nom }}</h5>
              <p class="text-gray-600">{{ article.description }}</p>
              <p class="mt-2 text-xl font-bold">{{ article.prix }} €</p>
              <a href="#" class="mt-4 block text-center bg-blue-500 text-white rounded-md py-2 hover:bg-blue-600">Acheter</a>
            </div>
          </div>
        {% endfor %}
      </div>
    </section>
  </main>

  <footer class="bg-gray-800 text-white text-center p-4 mt-8">
    <p>&copy; {{ "now"|date("Y") }} SneakerShop. Tous droits réservés.</p>
  </footer>
{% endblock %}
