{# templates/landing/index.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}Bienvenue sur SneakerShop{% endblock %}

{% block body %}
  <header>
    <nav>
      <a href="{{ path('landing') }}">SneakerShop</a>
      <ul>
        <li><a href="{{ path('profile') }}">Mon Profil</a></li>
        <li><a href="{{ path('article_list') }}">Sneakers</a></li>
      </ul>
    </nav>
  </header>

  <main>
    <section class="hero">
      <h1>Bienvenue sur SneakerShop</h1>
      <p>Découvrez nos sneakers exclusives et trouvez la paire parfaite pour vous.</p>
      <a class="btn btn-primary" href="{{ path('article_list') }}">Voir les sneakers</a>
    </section>
  </main>

  <footer>
    <p>&copy; {{ "now"|date("Y") }} SneakerShop. Tous droits réservés.</p>
  </footer>
{% endblock %}
